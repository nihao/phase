{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and subscription data",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "isPrime": { "type": "boolean", "description": "Whether the user has an active Phase Prime subscription" },
        "energyTokens": { "type": "number", "description": "Number of energy first aid kits available" },
        "totalSpent": { "type": "number", "description": "Total amount spent in the app (for Black Gold invite)" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "createdAt"]
    },
    "ChatMessage": {
      "title": "ChatMessage",
      "description": "A single message in the AI Energy Manager chat",
      "type": "object",
      "properties": {
        "role": { "type": "string", "enum": ["user", "model"] },
        "text": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["role", "text", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User profiles"
    },
    "/users/{userId}/messages/{messageId}": {
      "schema": { "$ref": "#/entities/ChatMessage" },
      "description": "Chat history for the user's AI Energy Manager"
    }
  }
}
