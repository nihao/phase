rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {userId}
    // Fields:
    //   - uid: string (required, immutable) - Firebase Auth UID
    //   - email: string (required, immutable) - User email
    //   - displayName: string (optional) - User display name
    //   - photoURL: string (optional) - User avatar URL
    //   - isPrime: boolean (optional, immutable by user) - Subscription status
    //   - energyTokens: number (optional, immutable by user) - Available tokens
    //   - totalSpent: number (optional, immutable by user) - Total spend
    //   - createdAt: timestamp (required, immutable) - Creation time
    //
    // Collection: users/{userId}/messages
    // Document ID: {messageId}
    // Fields:
    //   - role: string (required) - 'user' or 'model'
    //   - text: string (required) - Message content
    //   - createdAt: timestamp (required, immutable) - Creation time
    //
    // Collection: demo_purchases
    // Document ID: {purchaseId}
    // Fields:
    //   - uid: string (required, immutable)
    //   - item: string (required)
    //   - amount: number (required)
    //   - createdAt: timestamp (required, immutable)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.uid;
    }
    
    function uidUnchanged() {
      return !('uid' in request.resource.data) || request.resource.data.uid == request.auth.uid;
    }
    
    function uidNotModified() {
      return !('uid' in request.resource.data) || request.resource.data.uid == resource.data.uid;
    }
    
    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }
    
    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }
    
    function areImmutableFieldsUnchanged(fields) {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny(fields);
    }
    
    function isValidStringLength(field, minLen, maxLen) {
      return request.resource.data[field] is string &&
             request.resource.data[field].size() >= minLen &&
             request.resource.data[field].size() <= maxLen;
    }
    
    function isValidOptionalString(field, minLen, maxLen) {
      return !(field in request.resource.data) ||
             (request.resource.data[field] is string &&
              request.resource.data[field].size() >= minLen &&
              request.resource.data[field].size() <= maxLen);
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================

    function isValidUserCreate() {
      return hasRequiredFields(['uid', 'email', 'createdAt']) &&
             hasOnlyAllowedFields(['uid', 'email', 'displayName', 'photoURL', 'isPrime', 'energyTokens', 'totalSpent', 'createdAt']) &&
             request.resource.data.uid == request.auth.uid &&
             isValidStringLength('email', 3, 100) &&
             isValidOptionalString('displayName', 0, 50) &&
             isValidOptionalString('photoURL', 0, 500) &&
             (!( 'isPrime' in request.resource.data ) || request.resource.data.isPrime is bool) &&
             (!( 'energyTokens' in request.resource.data ) || request.resource.data.energyTokens is number) &&
             (!( 'totalSpent' in request.resource.data ) || request.resource.data.totalSpent is number) &&
             request.resource.data.createdAt is timestamp;
    }

    function isValidUserUpdate() {
      return hasOnlyAllowedFields(['uid', 'email', 'displayName', 'photoURL', 'isPrime', 'energyTokens', 'totalSpent', 'createdAt']) &&
             isValidOptionalString('displayName', 0, 50) &&
             isValidOptionalString('photoURL', 0, 500) &&
             areImmutableFieldsUnchanged(['uid', 'email', 'createdAt', 'isPrime', 'energyTokens', 'totalSpent']);
    }

    function isValidMessage() {
      return hasRequiredFields(['role', 'text', 'createdAt']) &&
             hasOnlyAllowedFields(['role', 'text', 'createdAt']) &&
             request.resource.data.role in ['user', 'model'] &&
             isValidStringLength('text', 1, 10000) &&
             request.resource.data.createdAt is timestamp;
    }

    function isValidDemoPurchase() {
      return hasRequiredFields(['uid', 'item', 'amount', 'createdAt']) &&
             hasOnlyAllowedFields(['uid', 'item', 'amount', 'createdAt']) &&
             request.resource.data.uid == request.auth.uid &&
             isValidStringLength('item', 1, 50) &&
             request.resource.data.amount is number &&
             request.resource.data.amount >= 0 &&
             request.resource.data.createdAt is timestamp;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUserCreate();
      allow update: if isOwner(userId) && isValidUserUpdate();
      allow delete: if false; // Prevent user deletion from client
      
      match /messages/{messageId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidMessage();
        allow update: if false; // Messages are immutable
        allow delete: if isOwner(userId); // Allow clearing chat history
      }
    }

    match /demo_purchases/{purchaseId} {
      allow read: if isDocOwner();
      allow create: if isAuthenticated() && isValidDemoPurchase();
      allow update: if false; // Purchases are immutable
      allow delete: if false;
    }
  }
}
